# ============================================================
# StudyAI — environment variables
# Copy this file to .env and fill in your key.
# ============================================================

# REQUIRED — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OPTIONAL — default model used for every generation
OPENROUTER_MODEL=openai/gpt-4o-mini

# OPTIONAL — attribution headers shown on your OpenRouter dashboard
OPENROUTER_SITE_URL=https://your-app.streamlit.app
