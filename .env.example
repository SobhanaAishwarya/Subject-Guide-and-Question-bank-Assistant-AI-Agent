# ==============================================================================
# Agentic AI Study Assistant (agentic_ai_clean) - Configuration Template
# Copy this file to '.env' locally. DO NOT commit your actual '.env' to Git.
# ==============================================================================

# OpenRouter / LLM Provider Configuration
# ------------------------------------------------------------------------------
# Paste your actual OpenRouter key (e.g., sk-or-v1-...) inside your local .env file.
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o

# Embedding Model Configuration
# ------------------------------------------------------------------------------
# OpenRouter handles completion models. For local embedding generation via LangChain,
# text-embedding-3-small will be initialized via standard OpenAI infrastructure.
# Note: If your OpenRouter API key lacks direct OpenAI vector access, ensure an 
# alternative embedding setup or standalone key if required by the vector factory.
EMBEDDING_MODEL=text-embedding-3-small

# Security and Cryptography
# ------------------------------------------------------------------------------
# Secret signature string for user session state consistency
SESSION_SECRET_KEY=super_secret_unpredictable_string_change_in_production

# Database Configuration
# ------------------------------------------------------------------------------
# Standard relational persistence engine using local SQLite
DATABASE_URL=sqlite:///agentic_study_assistant.db

# Storage Path Architecture
# ------------------------------------------------------------------------------
# Target folders where system data, indices, and runtime assets reside
UPLOAD_DIR=uploads
BUILT_IN_KB_DIR=knowledge_base
VECTOR_STORE_DIR=vectorstores

# System Metrics and Logging
# ------------------------------------------------------------------------------
# Available verbosity targets: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO